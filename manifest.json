{
  "manifest_version": 3,
  "name": "Meet Transcriber",
  "version": "0.1.0",
  "description": "Transcription audio d'appels Google Meet via l'API OpenAI",
  "permissions": ["tabCapture", "offscreen", "storage", "notifications", "activeTab", "nativeMessaging"],
  "host_permissions": ["https://api.openai.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meet Transcriber"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "116"
}
